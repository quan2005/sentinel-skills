{
  "mcpServers": {
    "my-custom-app": {
      "command": "uv",
      "args": ["run", "my-custom-app-server"],
      "cwd": "/path/to/my-custom-app"
    },
    "web-api-client": {
      "command": "uv",
      "args": ["run", "web-api-server"],
      "cwd": "/path/to/web-api-client",
      "env": {
        "API_TOKEN": "your_api_token_here",
        "API_BASE_URL": "https://api.example.com"
      }
    },
    "database-proxy": {
      "command": "uv",
      "args": ["run", "database-server"],
      "cwd": "/path/to/database-proxy",
      "env": {
        "DATABASE_URL": "postgresql+asyncpg://user:password@localhost:5432/dbname"
      }
    },
    "file-processor": {
      "command": "uv",
      "args": ["run", "file-processor-server"],
      "cwd": "/path/to/file-processor",
      "env": {
        "MAX_FILE_SIZE": "104857600",
        "UPLOAD_DIR": "./uploads"
      }
    }
  }
}