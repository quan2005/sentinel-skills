{
  "name": "Business Presentation Template",
  "description": "Professional business presentation template with data visualizations",
  "theme": "corporate",
  "type": "business",
  "default_config": {
    "theme": "corporate",
    "aspect_ratio": "16:9",
    "canvas_width": 1280,
    "primary_color": "#1e40af",
    "secondary_color": "#64748b",
    "accent_color": "#f59e0b"
  },
  "slides": [
    {
      "type": "cover",
      "title": "Business Title",
      "subtitle": "Professional subtitle",
      "author": "Your Name",
      "company": "Company Name"
    },
    {
      "type": "agenda",
      "title": "Agenda",
      "items": [
        "Market Analysis",
        "Strategic Overview",
        "Financial Performance",
        "Future Outlook"
      ]
    },
    {
      "type": "content",
      "title": "Market Analysis",
      "layout": "two-cols",
      "left_content": {
        "heading": "Market Size",
        "content": "$2.8B global market",
        "metrics": [
          {"label": "Growth Rate", "value": "15.3%", "trend": "up"},
          {"label": "Market Share", "value": "23%", "trend": "up"}
        ]
      },
      "right_content": {
        "heading": "Key Trends",
        "points": [
          "Digital transformation accelerating",
          "Customer expectations rising",
          "Competition intensifying"
        ]
      }
    },
    {
      "type": "chart",
      "title": "Financial Performance",
      "chart_type": "line",
      "data": {
        "labels": ["Q1", "Q2", "Q3", "Q4"],
        "datasets": [
          {
            "label": "Revenue",
            "data": [100, 120, 140, 180],
            "color": "#1e40af"
          },
          {
            "label": "Profit",
            "data": [20, 30, 45, 60],
            "color": "#10b981"
          }
        ]
      }
    }
  ]
}